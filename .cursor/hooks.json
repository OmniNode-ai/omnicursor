{
  "version": 1,
  "hooks": {
    "beforeSubmitPrompt": [
      {
        "command": "python3 .cursor/hooks/scripts/user-prompt-submit.py"
      }
    ],
    "beforeShellExecution": [
      {
        "command": "python3 .cursor/hooks/scripts/shell-guard.py"
      }
    ],
    "afterFileEdit": [
      {
        "command": "python3 .cursor/hooks/on_edit.py"
      }
    ],
    "stop": [
      {
        "command": "python3 .cursor/hooks/on_stop.py"
      }
    ]
  }
}
